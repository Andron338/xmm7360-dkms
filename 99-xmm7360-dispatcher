#!/bin/bash
# /etc/NetworkManager/dispatcher.d/99-xmm7360

IFACE="$1"
ACTION="$2"

[[ "$IFACE" == ppp* || "$IFACE" == "wwan0" ]] || exit 0
[ "$ACTION" = "down" ] || exit 0

logger -t xmm7360-dispatcher "$IFACE went down — triggering recovery"

# --no-block so NM doesn't wait for recovery to complete
systemctl start --no-block xmm7360-recovery.service

exit 0
