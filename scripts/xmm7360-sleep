#!/bin/bash
# /usr/lib/systemd/system-sleep/xmm7360
#
# Make the modem SAFE to suspend/hibernate by ensuring NO userspace process
# holds its char/tty devices open before the kernel tears the driver down.
#
# Why this is required:
#   The PCIe modem's data path uses live DMA rings, and the driver's PM
#   notifier unbinds the driver (pci_unregister_driver) across the sleep
#   transition to avoid resuming with stale device state. BUT the driver's
#   per-channel cdev and tty_port structs are embedded in a queue_pair that
#   the teardown frees/zeroes. If ModemManager (which keeps the ttyXMM AT
#   ports open) or pppd / open_xdatachannel still hold those fds when the
#   unbind runs, their later close() walks freed kernel structures —
#   corrupting a cdev list (-> kernel oops in cdev_put/cd_forget) or
#   deadlocking in tty_release on a zeroed mutex (-> hibernate freeze fails,
#   UI wedges). Cold-boot suspend works only because nothing holds the ports
#   yet; after a few minutes of real use MM/pppd do, and it crashes.
#
#   userspace system-sleep hooks run BEFORE the kernel PM notifier, so this
#   is the correct place to release every fd first. We stop ModemManager so
#   it closes the tty ports, kill any pppd/tool still holding a port, and
#   only THEN let the kernel unbind cleanly.
#
# systemd calls this as:  xmm7360 {pre|post} {suspend|hibernate|...}

phase="$1"
log() { logger -t xmm7360-sleep "$*"; }

case "$phase" in
    pre)
        log "pre-sleep: releasing all modem fds before kernel unbind"

        # 1. Bring down any active gsm/modem NM connection (drops pppd cleanly).
        for c in $(nmcli -t -f NAME,TYPE connection show --active 2>/dev/null \
                   | awk -F: '$2=="gsm"{print $1}'); do
            log "  nmcli down: $c"
            timeout 8 nmcli connection down "$c" 2>/dev/null || true
        done

        # 2. Stop ModemManager so it CLOSES the ttyXMM AT ports. This is the
        #    key step: while MM runs it keeps those ports open, and the kernel
        #    unbind would free them out from under it. Stopping MM (and waiting
        #    for it to exit) guarantees those fds are closed.
        if systemctl is-active --quiet ModemManager; then
            log "  stopping ModemManager (closes ttyXMM ports)"
            timeout 15 systemctl stop ModemManager 2>/dev/null || true
        fi

        # 3. Kill anything else still holding a modem device open.
        for proc in pppd open_xdatachannel; do
            if pgrep -x "$proc" >/dev/null 2>&1; then
                log "  killing $proc (still holding a port)"
                pkill -TERM -x "$proc" 2>/dev/null || true
            fi
        done
        sleep 1
        pkill -KILL -x pppd 2>/dev/null || true
        pkill -KILL -x open_xdatachannel 2>/dev/null || true

        # 4. Give the kernel a moment to process the closes before it unbinds.
        sleep 1
        log "pre-sleep: all modem fds released, safe to suspend"
        ;;

    post)
        log "post-resume: restarting ModemManager to re-probe the modem"
        # The kernel re-probed the device on resume (PM notifier rebind).
        # Restart MM so it re-detects the fresh modem and autoconnect resumes.
        timeout 15 systemctl start ModemManager 2>/dev/null || true
        ;;
esac

exit 0
