#!/bin/bash
# /usr/lib/systemd/system-sleep/xmm7360

case "$1" in
    pre)
        logger -t xmm7360-sleep "pre-suspend: clearing sentinel"
        rm -f /run/xmm7360-init.done
        ip link set wwan0 down 2>/dev/null || true
        sed -i '/# Added by xmm7360/,/^[^#]/{ /# Added by xmm7360/d; /^nameserver/d }' \
            /etc/resolv.conf 2>/dev/null || true
        ;;
    post)
        logger -t xmm7360-sleep "post-resume: triggering recovery"
        sleep 1
        systemctl start xmm7360-recovery.service
        ;;
esac
