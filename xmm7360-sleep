#!/bin/bash
# /usr/lib/systemd/system-sleep/xmm7360

case "$1" in
    pre)
        logger -t xmm7360-sleep "pre-suspend: preparing for sleep"
        rm -f /run/xmm7360-init.done
        ip link set wwan0 down 2>/dev/null || true
        ;;
    post)
        logger -t xmm7360-sleep "post-resume: triggering modem recovery"
        # --no-block: returns immediately so the resume path is not blocked.
        # Recovery runs in the background once the system is fully up.
        systemctl start --no-block xmm7360-recovery.service
        ;;
esac
