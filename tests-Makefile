# tests/Makefile — build and run userspace tests
#
# Usage:
#   make           — build all userspace tests
#   make test      — build and run all userspace tests
#   make kunit     — build KUnit kernel module tests
#   make clean

CC      ?= gcc
CFLAGS  := -std=c11 -Wall -Wextra -g -O0 -I..
LDFLAGS :=

# Sources from the rpc/ directory that tests link against
RPC_SRCS := \
    ../rpc/xmm_proto.c \
    ../rpc/xmm_rpc.c

# Needed by xmm_rpc.c
LDFLAGS += $(shell pkg-config --libs openssl 2>/dev/null || echo "-lssl -lcrypto")

BINS := test_proto test_rpc

.PHONY: all test kunit clean

all: $(BINS)

# test_proto exercises only the pack/unpack engine — no crypto needed,
# so it links without openssl (keeps the test buildable on minimal hosts).
test_proto: test_proto.c test_framework.h ../rpc/xmm_proto.c ../rpc/xmm_proto.h
	$(CC) $(CFLAGS) -o $@ test_proto.c ../rpc/xmm_proto.c

test_rpc: test_rpc.c test_framework.h $(RPC_SRCS) \
          ../rpc/xmm_rpc.h ../rpc/xmm_rpc_ids.h ../rpc/xmm_unsol.h
	$(CC) $(CFLAGS) -o $@ test_rpc.c $(RPC_SRCS) \
	    ../rpc/xmm_netlink.c \
	    $(LDFLAGS) -luuid

test: $(BINS)
	@echo ""
	@echo "══ test_proto ════════════════════════════════════════════"
	@./test_proto
	@echo ""
	@echo "══ test_rpc ══════════════════════════════════════════════"
	@./test_rpc
	@echo ""

kunit:
	make -C /lib/modules/$$(uname -r)/build \
	    M=$$(dirname $$(pwd))/tests \
	    CONFIG_XMM7360_KUNIT_TEST=m \
	    modules

clean:
	rm -f $(BINS) *.o *.ko *.mod.c *.mod .*.cmd Module.symvers modules.order
